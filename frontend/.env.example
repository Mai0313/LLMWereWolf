# 公司 API 配置
REACT_APP_API_BASE_URL=http://localhost:8000/api
REACT_APP_WS_URL=ws://localhost:8000/ws

# 公司 LLM API 服务器
REACT_APP_LLM_SERVER_1=http://100.80.20.5:4000/v1
REACT_APP_LLM_SERVER_2=http://100.82.5.110:30001

# 可用模型配置
REACT_APP_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# 开发配置
GENERATE_SOURCEMAP=true
PORT=3000

# 功能开关
REACT_APP_ENABLE_MOCK_DATA=true
REACT_APP_ENABLE_DEBUG=true

# 可选：API 密钥（如果需要）
# REACT_APP_OPENAI_API_KEY=your_openai_key_here
# REACT_APP_ANTHROPIC_API_KEY=your_anthropic_key_here

# 生产环境配置
# REACT_APP_API_BASE_URL=https://your-production-api.com/api
# REACT_APP_WS_URL=wss://your-production-api.com/ws
# GENERATE_SOURCEMAP=false